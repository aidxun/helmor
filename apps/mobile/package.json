{
	"name": "@helmor/mobile",
	"description": "Helmor mobile control surface.",
	"version": "0.0.0",
	"main": "index.ts",
	"scripts": {
		"start": "expo start --dev-client",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"web": "expo start --web",
		"typecheck": "tsc --noEmit",
		"build:ios:sim": "bunx eas-cli build -p ios --profile development-simulator",
		"build:ios:device": "bunx eas-cli build -p ios --profile development-device"
	},
	"dependencies": {
		"expo": "^55.0.19",
		"expo-dev-client": "~55.0.30",
		"expo-status-bar": "~55.0.5",
		"react": "19.2.0",
		"react-native": "0.83.6"
	},
	"devDependencies": {
		"@types/react": "~19.2.10",
		"typescript": "~5.9.2"
	},
	"private": true
}
